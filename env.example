# .env.example — Waking Cup Pipeline Configuration
# Copy to .env and fill in your values.
# Never commit .env to git.

# ── Marketplace API credentials ────────────────────────────────────────────
LAZADA_APP_KEY=your_app_key
LAZADA_APP_SECRET=your_app_secret
LAZADA_ACCESS_TOKEN=your_access_token

# ── Paths (defaults work if running from /home/wcpipeline) ────────────────
# BASE_DIR=/home/wcpipeline
# SCHEMA_DIR=/home/wcpipeline/product_schema
# BACKUP_DIR=/home/wcpipeline/backups

# ── Hostinger SFTP ─────────────────────────────────────────────────────────
SFTP_HOST=your_server_ip
SFTP_PORT=65002
SFTP_USER=your_hostinger_username
# SFTP_PASSWORD=your_password          # not recommended — use key auth instead
SFTP_KEY_PATH=/home/wcpipeline/.ssh/hostinger_key

# ── Pipeline behaviour ─────────────────────────────────────────────────────
# DRY_RUN=false
# SKIP_DEPLOY=false
# BACKFILL_SINCE=                      # YYYY-MM-DD for one-time backfill runs
